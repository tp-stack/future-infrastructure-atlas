# Local project settings
ATLAS_ENV=development
ATLAS_STORAGE_ROOT=data
ATLAS_LOG_LEVEL=INFO

# Future object storage settings. Leave unset for local-only Step 1.
ATLAS_OBJECT_STORAGE_BUCKET=
ATLAS_OBJECT_STORAGE_PREFIX=

# Local PostGIS settings for Step 2 development.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=future_atlas
DATABASE_USER=future_atlas
DATABASE_PASSWORD=future_atlas_dev_password
DATABASE_URL=postgresql://future_atlas:future_atlas_dev_password@localhost:5432/future_atlas

# Stripe Payment Integration Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE

# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe recurring Price IDs for commercial API subscriptions
STRIPE_PRICE_LAUNCH=price_YOUR_LAUNCH_PRICE_ID
STRIPE_PRICE_SCALE=price_YOUR_SCALE_PRICE_ID
STRIPE_PRICE_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID
PUBLIC_APP_URL=http://127.0.0.1:5174

# Site Selection Storage
# Override default storage path (data/reports/site_selection) for JSONL candidate files.
SITE_SELECTION_STORAGE_DIR=
# Number of days to retain candidate query JSONL files before cleanup (default 7).
SITE_SELECTION_RETENTION_DAYS=7
