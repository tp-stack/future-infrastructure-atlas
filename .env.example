# Local project settings
ATLAS_ENV=development
ATLAS_STORAGE_ROOT=data
ATLAS_LOG_LEVEL=INFO

# Future object storage settings. Leave unset for local-only Step 1.
ATLAS_OBJECT_STORAGE_BUCKET=
ATLAS_OBJECT_STORAGE_PREFIX=

# Local PostGIS settings for Step 2 development.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=future_atlas
DATABASE_USER=future_atlas
DATABASE_PASSWORD=future_atlas_dev_password
DATABASE_URL=postgresql://future_atlas:future_atlas_dev_password@localhost:5432/future_atlas
