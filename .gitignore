# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
!.env.example

# Local editor and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/
.agentmemory/

# Heavy local data directories
data/raw/**
data/staging/**
data/processed/**
data/tiles/**
data/cache/**
data/reports/**
data/logs/**

# Keep data directory documentation and placeholders
!data/README.md
!data/**/.gitkeep

# Generated geospatial, raster, tile, tabular, and local database outputs
*.geojson
*.gpkg
*.shp
*.dbf
*.shx
*.prj
*.pbf
*.mbtiles
*.pmtiles
*.tif
*.tiff
*.nc
*.grib
*.parquet
*.duckdb
*.sqlite
frontend/public/tiles/*.pmtiles
!frontend/public/tiles/.gitkeep

# Frontend dependencies and builds
node_modules/
frontend/node_modules/
frontend/dist/

# Tiny fixtures are allowed for tests only
!tests/fixtures/
!tests/fixtures/**

.vercel
.env*.local

# Raw data artifacts must not be served from public
frontend/public/data/*.csv
frontend/public/data/*.geojson
